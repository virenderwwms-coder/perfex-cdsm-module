<?php
defined('BASEPATH') or exit('No direct script access allowed');

class Cron extends CI_Controller
{
    public function __construct()
    {
        parent::__construct();
        
        // Only allow CLI execution
        if (!$this->input->is_cli_request()) {
            show_error('Cron jobs can only be run from the command line', 403);
        }

        $this->load->model('cdsm_reminders_model');
        $this->load->model('cdsm_documents_model');
        $this->load->library('email');
        $this->load->helper('cdsm_email_helper');
    }

    /**
     * Process pending reminders and send notifications
     */
    public function process_reminders()
    {
        echo "Starting reminder processing...\n";

        try {
            $this->load->helper('cdsm_email_helper');
            $email_helper = new Cdsm_email_helper();

            // Get pending reminders
            $pending_reminders = $this->cdsm_reminders_model->get_pending_reminders();

            if (empty($pending_reminders)) {
                echo "No pending reminders to process.\n";
                log_message('info', 'CDSM Cron: No pending reminders');
                return;
            }

            echo "Found " . count($pending_reminders) . " pending reminders\n";

            foreach ($pending_reminders as $reminder) {
                $days_left = $reminder->reminder_days;

                echo "Processing reminder for: {$reminder->document_name} - Days: {$days_left}\n";

                // Send email to staff
                $email_helper->send_reminder_email($reminder, $days_left);

                // Send email to customer if critical
                if ($days_left <= 7 && $days_left > 0) {
                    $email_helper->send_customer_notification($reminder);
                } elseif ($days_left == 0) {
                    $email_helper->send_customer_notification($reminder);
                }

                // Mark as notified
                $this->cdsm_reminders_model->mark_as_notified($reminder->id);

                echo "  ✓ Reminder processed and marked as notified\n";
            }

            echo "Reminder processing completed successfully.\n";
            log_message('info', 'CDSM Cron: Successfully processed ' . count($pending_reminders) . ' reminders');

        } catch (Exception $e) {
            echo "Error: " . $e->getMessage() . "\n";
            log_message('error', 'CDSM Cron Error: ' . $e->getMessage());
        }
    }

    /**
     * Generate reminders for upcoming expiries
     */
    public function generate_reminders()
    {
        echo "Starting reminder generation...\n";

        try {
            // This would be called once per day to create reminders
            // Already handled in the add_document method, but can be used for bulk generation

            echo "Reminder generation completed.\n";
            log_message('info', 'CDSM Cron: Reminder generation completed');

        } catch (Exception $e) {
            echo "Error: " . $e->getMessage() . "\n";
            log_message('error', 'CDSM Cron Error: ' . $e->getMessage());
        }
    }

    /**
     * Clean up old notifications
     */
    public function cleanup()
    {
        echo "Starting cleanup...\n";

        try {
            // Delete notified reminders older than 6 months
            $six_months_ago = date('Y-m-d', strtotime('-6 months'));
            
            $this->db->where('is_notified', 1);
            $this->db->where('notified_at <', $six_months_ago);
            $deleted = $this->db->delete('tblcdsm_reminders');

            echo "Deleted {$deleted} old reminders.\n";
            log_message('info', 'CDSM Cron: Cleanup completed - deleted ' . $deleted . ' old reminders');

        } catch (Exception $e) {
            echo "Error: " . $e->getMessage() . "\n";
            log_message('error', 'CDSM Cron Error: ' . $e->getMessage());
        }
    }
}
?>
