<?php
defined('BASEPATH') or exit('No direct script access allowed');

// Module activation hook
register_activation_hook('cdsm', 'cdsm_module_activate');
register_deactivation_hook('cdsm', 'cdsm_module_deactivate');

function cdsm_module_activate()
{
    $CI = &get_instance();
    $CI->load->model('migration_model');
    
    // Run migrations
    if (!$CI->migration->current()) {
        show_error('Migration failed: ' . $CI->migration->error_string());
    }

    // Create database tables
    $CI->load->dbforge();

    // Check if table already exists
    if (!$CI->db->table_exists('tblcdsm_documents')) {
        $CI->dbforge->add_field(array(
            'id' => array(
                'type' => 'INT',
                'constraint' => 11,
                'unsigned' => TRUE,
                'auto_increment' => TRUE
            ),
            'customer_id' => array(
                'type' => 'INT',
                'constraint' => 11,
                'unsigned' => TRUE
            ),
            'document_name' => array(
                'type' => 'VARCHAR',
                'constraint' => 255
            ),
            'document_type' => array(
                'type' => 'VARCHAR',
                'constraint' => 100
            ),
            'file_path' => array(
                'type' => 'VARCHAR',
                'constraint' => 500,
                'null' => TRUE
            ),
            'issue_date' => array(
                'type' => 'DATE'
            ),
            'expiry_date' => array(
                'type' => 'DATE'
            ),
            'notes' => array(
                'type' => 'TEXT',
                'null' => TRUE
            ),
            'created_by' => array(
                'type' => 'INT',
                'constraint' => 11,
                'unsigned' => TRUE
            ),
            'created_at' => array(
                'type' => 'DATETIME'
            ),
            'updated_at' => array(
                'type' => 'DATETIME',
                'null' => TRUE
            )
        ));
        
        $CI->dbforge->add_key('id', TRUE);
        $CI->dbforge->add_key('customer_id');
        $CI->dbforge->add_key('expiry_date');
        $CI->dbforge->create_table('tblcdsm_documents');
    }

    if (!$CI->db->table_exists('tblcdsm_reminders')) {
        $CI->dbforge->add_field(array(
            'id' => array(
                'type' => 'INT',
                'constraint' => 11,
                'unsigned' => TRUE,
                'auto_increment' => TRUE
            ),
            'document_id' => array(
                'type' => 'INT',
                'constraint' => 11,
                'unsigned' => TRUE
            ),
            'reminder_days' => array(
                'type' => 'INT',
                'constraint' => 3
            ),
            'reminder_date' => array(
                'type' => 'DATE'
            ),
            'is_notified' => array(
                'type' => 'TINYINT',
                'constraint' => 1,
                'default' => 0
            ),
            'notified_at' => array(
                'type' => 'DATETIME',
                'null' => TRUE
            ),
            'created_at' => array(
                'type' => 'DATETIME'
            )
        ));
        
        $CI->dbforge->add_key('id', TRUE);
        $CI->dbforge->add_key('document_id');
        $CI->dbforge->add_key('reminder_date');
        $CI->dbforge->create_table('tblcdsm_reminders');
    }

    // Create default settings
    add_option('cdsm_reminder_30_days', 30);
    add_option('cdsm_reminder_15_days', 15);
    add_option('cdsm_reminder_7_days', 7);
    add_option('cdsm_enable_email_reminders', 1);

    log_message('info', 'CDSM Module activated successfully');
}

function cdsm_module_deactivate()
{
    log_message('info', 'CDSM Module deactivated');
    // Note: Don't delete tables on deactivation - preserve data
}
?>
