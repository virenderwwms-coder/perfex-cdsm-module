<?php defined('BASEPATH') or exit('No direct script access allowed'); ?>

<div class="container mt-5">
    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header bg-light">
                    <h4 class="card-title mb-0"><?php echo _l('cdsm_my_documents'); ?></h4>
                </div>
                <div class="card-body">
                    <?php if (!empty($documents)) { ?>
                        <!-- Summary Cards -->
                        <div class="row mb-4">
                            <div class="col-md-3">
                                <div class="cdsm-stats-card">
                                    <div class="number" style="color: #28a745;"><?php echo count(array_filter($documents, function($d) { return strtotime($d->expiry_date) > strtotime('+30 days'); })); ?></div>
                                    <div class="label">Valid</div>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="cdsm-stats-card">
                                    <div class="number" style="color: #ffc107;"><?php echo count(array_filter($documents, function($d) { $days = floor((strtotime($d->expiry_date) - time()) / 86400); return $days > 7 && $days <= 30; })); ?></div>
                                    <div class="label">Follow-up</div>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="cdsm-stats-card">
                                    <div class="number" style="color: #fd7e14;"><?php echo count(array_filter($documents, function($d) { $days = floor((strtotime($d->expiry_date) - time()) / 86400); return $days >= 0 && $days <= 7; })); ?></div>
                                    <div class="label">Critical</div>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="cdsm-stats-card">
                                    <div class="number" style="color: #dc3545;"><?php echo count(array_filter($documents, function($d) { return strtotime($d->expiry_date) < time(); })); ?></div>
                                    <div class="label">Expired</div>
                                </div>
                            </div>
                        </div>

                        <!-- Documents Table -->
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th><?php echo _l('cdsm_document_name'); ?></th>
                                        <th><?php echo _l('cdsm_document_type'); ?></th>
                                        <th><?php echo _l('cdsm_issue_date'); ?></th>
                                        <th><?php echo _l('cdsm_expiry_date'); ?></th>
                                        <th><?php echo _l('cdsm_days_left'); ?></th>
                                        <th><?php echo _l('cdsm_status'); ?></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <?php foreach ($documents as $doc) {
                                        $this->load->model('cdsm_documents_model');
                                        $status_info = $this->cdsm_documents_model->get_document_status($doc);
                                    ?>
                                        <tr>
                                            <td><strong><?php echo htmlspecialchars($doc->document_name); ?></strong></td>
                                            <td><?php echo htmlspecialchars($doc->document_type); ?></td>
                                            <td><?php echo _d($doc->issue_date); ?></td>
                                            <td><?php echo _d($doc->expiry_date); ?></td>
                                            <td>
                                                <span class="cdsm-days-counter" style="background-color: <?php echo $status_info['color']; ?>; color: white;">
                                                    <?php echo $status_info['days']; ?> days
                                                </span>
                                            </td>
                                            <td>
                                                <span class="cdsm-status-badge" data-status="<?php echo $status_info['status']; ?>">
                                                    <?php echo ucfirst(str_replace('_', ' ', $status_info['status'])); ?>
                                                </span>
                                            </td>
                                        </tr>
                                    <?php } ?>
                                </tbody>
                            </table>
                        </div>
                    <?php } else { ?>
                        <div class="alert alert-info">
                            <i class="fa fa-info-circle"></i> You have no documents on file
                        </div>
                    <?php } ?>
                </div>
            </div>
        </div>
    </div>
</div>
