<?php defined('BASEPATH') or exit('No direct script access allowed'); ?>

<div class="container-fluid cdsm-container">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card">
                <div class="card-header bg-light">
                    <h4 class="card-title"><?php echo $title; ?></h4>
                </div>
                <div class="card-body">
                    <?php echo form_open_multipart(current_url(), array('class' => 'form-horizontal')); ?>
                    
                    <div class="form-group row">
                        <label class="col-md-3 col-form-label" for="customer_id">
                            <?php echo _l('cdsm_customer'); ?> <span class="text-danger">*</span>
                        </label>
                        <div class="col-md-9">
                            <select name="customer_id" id="customer_id" class="form-control" required>
                                <option value="">-- <?php echo _l('select'); ?> --</option>
                                <?php foreach ($customers as $customer) { ?>
                                    <option value="<?php echo $customer->userid; ?>" 
                                        <?php if (!empty($document) && $document->customer_id == $customer->userid) echo 'selected'; ?>>
                                        <?php echo htmlspecialchars($customer->company); ?>
                                    </option>
                                <?php } ?>
                            </select>
                        </div>
                    </div>

                    <div class="form-group row">
                        <label class="col-md-3 col-form-label" for="document_name">
                            <?php echo _l('cdsm_document_name'); ?> <span class="text-danger">*</span>
                        </label>
                        <div class="col-md-9">
                            <input type="text" name="document_name" id="document_name" class="form-control" 
                                value="<?php echo !empty($document) ? htmlspecialchars($document->document_name) : ''; ?>" 
                                placeholder="e.g., Passport, License, Certificate" required>
                        </div>
                    </div>

                    <div class="form-group row">
                        <label class="col-md-3 col-form-label" for="document_type">
                            <?php echo _l('cdsm_document_type'); ?> <span class="text-danger">*</span>
                        </label>
                        <div class="col-md-9">
                            <select name="document_type" id="document_type" class="form-control" required>
                                <option value="">-- <?php echo _l('select'); ?> --</option>
                                <?php foreach ($document_types as $key => $type) { ?>
                                    <option value="<?php echo $key; ?>"
                                        <?php if (!empty($document) && $document->document_type == $key) echo 'selected'; ?>>
                                        <?php echo $type; ?>
                                    </option>
                                <?php } ?>
                            </select>
                        </div>
                    </div>

                    <div class="form-group row">
                        <label class="col-md-3 col-form-label" for="issue_date">
                            <?php echo _l('cdsm_issue_date'); ?> <span class="text-danger">*</span>
                        </label>
                        <div class="col-md-9">
                            <input type="date" name="issue_date" id="issue_date" class="form-control"
                                value="<?php echo !empty($document) ? $document->issue_date : ''; ?>" required>
                        </div>
                    </div>

                    <div class="form-group row">
                        <label class="col-md-3 col-form-label" for="expiry_date">
                            <?php echo _l('cdsm_expiry_date'); ?> <span class="text-danger">*</span>
                        </label>
                        <div class="col-md-9">
                            <input type="date" name="expiry_date" id="expiry_date" class="form-control"
                                value="<?php echo !empty($document) ? $document->expiry_date : ''; ?>" required>
                            <small class="form-text text-muted">Reminders will be set at 30, 15, 7 days and on expiry date</small>
                        </div>
                    </div>

                    <div class="form-group row">
                        <label class="col-md-3 col-form-label" for="notes">
                            <?php echo _l('cdsm_notes'); ?>
                        </label>
                        <div class="col-md-9">
                            <textarea name="notes" id="notes" class="form-control" rows="4"><?php echo !empty($document) ? htmlspecialchars($document->notes) : ''; ?></textarea>
                        </div>
                    </div>

                    <div class="form-group row">
                        <div class="col-md-9 offset-md-3">
                            <button type="submit" class="btn btn-primary">
                                <i class="fa fa-save"></i> <?php echo _l('save'); ?>
                            </button>
                            <a href="<?php echo admin_url('cdsm'); ?>" class="btn btn-secondary">
                                <i class="fa fa-times"></i> <?php echo _l('cancel'); ?>
                            </a>
                        </div>
                    </div>

                    <?php echo form_close(); ?>
                </div>
            </div>
        </div>
    </div>
</div>
